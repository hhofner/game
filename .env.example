# Copy to .env and fill in. Never commit .env.

# Supabase (read by @nuxtjs/supabase)
SUPABASE_URL=
SUPABASE_KEY=                 # publishable key (client-side)
NUXT_SUPABASE_SECRET_KEY=     # secret key (server only: ingestion / scoring)

# API-Football (api-football.com / api-sports.io) key (server only)
NUXT_API_FOOTBALL_KEY=

# Admin key guarding admin/cron routes in production (server only)
NUXT_ADMIN_KEY=
